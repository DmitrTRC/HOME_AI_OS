# ============================================================
# HOME AI OS — Environment Configuration
# ============================================================
# Скопируй этот файл в .env и заполни свои значения:
#   cp .env.example .env
#
# НИКОГДА не коммить .env в git!
# ============================================================

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-string-at-least-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database (PostgreSQL) ---
# Для dev: используется контейнер из docker-compose
# Для prod: Selectel Managed PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=unified_ops
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev_password_change_me
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Celery ---
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# --- S3 Object Storage ---
# Dev: MinIO (в docker-compose)
# Prod: Selectel S3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=home-ai-os
S3_REGION=ru-1

# --- Telegram Bot ---
# Получи токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook

# --- AI: Anthropic Claude ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- AI: Ollama (local models for sensitive data) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# --- AI: Whisper (transcription) ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
# Поменяй на cuda если есть GPU

# --- Mail Intake (IMAP) ---
# Раскомментируй когда будешь настраивать почту
# MAIL_IMAP_HOST=imap.example.com
# MAIL_IMAP_PORT=993
# MAIL_IMAP_USER=your-email@example.com
# MAIL_IMAP_PASSWORD=your-email-password
# MAIL_CHECK_INTERVAL_SECONDS=300

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FORMAT=console
# Для prod: LOG_FORMAT=json
